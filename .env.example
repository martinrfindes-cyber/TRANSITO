# --- Defensor Vial MX — variables de entorno ---
# Copia este archivo como ".env" y completa los valores.

# Token del bot de Telegram (obtenlo con @BotFather en Telegram).
TELEGRAM_BOT_TOKEN=

# --- Proveedor de LLM (generación de respuestas) ---
LLM_PROVIDER=openai
# Clave de la API de OpenAI (https://platform.openai.com/api-keys).
OPENAI_API_KEY=
# Modelo a usar. "gpt-4o-mini" es económico; "gpt-4o" da mayor precisión.
OPENAI_MODEL=gpt-4o-mini
# Modelo para análisis de imágenes (boletas). gpt-4o-mini ya soporta visión.
# Si lo dejas vacío, usa el mismo de OPENAI_MODEL.
OPENAI_VISION_MODEL=gpt-4o-mini
# Opcional: endpoint compatible (déjalo así para usar OpenAI directo).
OPENAI_BASE_URL=https://api.openai.com/v1
# Temperatura baja = respuestas más precisas y deterministas.
LLM_TEMPERATURE=0.2

# --- Base de conocimiento / RAG ---
# Ruta a la carpeta con los .md (por defecto ./knowledge).
# KNOWLEDGE_DIR=
RAG_TOP_K=6
RAG_MIN_SCORE=0.05

# --- Historial de conversación ---
HISTORY_MAX_TURNS=8

# --- Bóveda de evidencia (Fase 4) ---
# Carpeta donde se guardan fotos/video/audio/ubicación (por defecto ./evidence).
# EVIDENCE_DIR=
# Tamaño máximo por archivo descargado de Telegram, en MB (0 = sin límite).
EVIDENCE_MAX_MB=20
